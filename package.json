{
  "name": "verso",
  "version": "0.1.55",
  "description": "Verso — a fast, private, open-source PDF viewer and editor for the desktop.",
  "homepage": "https://versoeditor.com",
  "license": "MIT",
  "author": {
    "name": "Verso contributors",
    "email": "noreply@versoeditor.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/soldforaloss/verso.git"
  },
  "main": "./out/main/index.js",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "preview": "electron-vite preview",
    "build": "npm run typecheck && electron-vite build",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"tests/**/*.{ts,tsx}\" \"*.{json,md,yml}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"tests/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "fixtures": "node scripts/generate-fixtures.mjs",
    "fetch:qpdf": "node scripts/fetch-qpdf.mjs",
    "icon": "node scripts/generate-icon.mjs",
    "screenshot": "node scripts/screenshot.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@embedpdf/pdfium": "2.14.4",
    "@hyzyla/pdfium": "2.1.13",
    "@pdf-lib/fontkit": "^1.1.1",
    "@signpdf/placeholder-plain": "3.3.0",
    "@signpdf/signer-p12": "3.3.0",
    "@signpdf/signpdf": "3.3.0",
    "@tesseract.js-data/deu": "^1.0.0",
    "@tesseract.js-data/eng": "^1.0.0",
    "@tesseract.js-data/fra": "^1.0.0",
    "@tesseract.js-data/ita": "^1.0.0",
    "@tesseract.js-data/nld": "^1.0.0",
    "@tesseract.js-data/por": "^1.0.0",
    "@tesseract.js-data/rus": "^1.0.0",
    "@tesseract.js-data/spa": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "immer": "^11.1.8",
    "lucide-react": "^1.21.0",
    "node-forge": "1.3.3",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.0.227",
    "tailwind-merge": "^3.6.0",
    "tesseract.js": "^7.0.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.1",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.20.0",
    "@types/node-forge": "1.3.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^7.3.5",
    "vite-plugin-static-copy": "^4.1.1",
    "vitest": "^4.1.9"
  }
}
